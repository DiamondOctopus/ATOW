<section
        class="tab scrollable inventory {{tabs.inventory.cssClass}}"
        data-group="primary"
        data-tab="inventory"
>
    <ul>
        {{#each gear as |item id| }}
            <li class='item flexrow' data-item-id='{{item._id}}'>
                <div class='item-name'>
                    <h4>{{item.name}}</h4>
                </div>
            </li>
        {{/each}}
    </ul>

</section>